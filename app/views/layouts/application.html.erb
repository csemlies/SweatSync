<!doctype html>
<html>
<head>
  <title>SweatSync</title>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= stylesheet_link_tag "application", media: "all", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
  <meta name="viewport" content="width=device-width,initial-scale=1">
</head>

<body>
  <header class="container" style="margin-top: 1rem; display:flex; align-items:center; justify-content:space-between;">
    <div>
      <a href="<%= root_path %>" style="text-decoration:none;"><strong>SweatSync</strong></a>
    </div>

    <nav>
      <% if user_signed_in? %>
        <%= link_to "Profile", profile_path, style: "margin-right: 1rem;" %>
        <%= link_to "Edit profile", edit_user_registration_path, style: "margin-right: 1rem;" %>
        <%= link_to "Sign out", destroy_user_session_path, method: :delete %>
      <% else %>
        <%= link_to "Log in", new_user_session_path, style: "margin-right: 1rem;" %>
        <%= link_to "Sign up", new_user_registration_path %>
      <% end %>
    </nav>
  </header>

  <main class="container" style="margin-top: 2rem;">
    <%= yield %>
  </main>

  <footer class="container" style="margin-top: 4rem; padding: 1rem 0; color:#666;">
    <div style="display:flex; justify-content:space-between;">
      <div><strong>SweatSync</strong></div>
      <div><%= link_to "Home", root_path %></div>
    </div>
  </footer>
</body>
</html>
