<!DOCTYPE html>
<html>
  <head>
    <title>SweatSync</title>
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <!-- Pico CSS (CDN) -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css">

    <!-- app CSS / compiled assets -->
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <!-- top nav (pico-friendly) -->
    <header class="container" style="margin-top: 1rem;">
      <nav role="navigation" aria-label="Main navigation">
        <ul>
          <li><a href="<%= root_path %>" style="text-decoration:none;"><strong>SweatSync</strong></a></li>
        </ul>

        <ul style="float:right; list-style:none; margin:0; padding:0;">
          <% if user_signed_in? %>
            <%# compute profile link (use profile_path if defined, otherwise user_path(current_user)) %>
            <% profile_link_path = (defined?(profile_path) ? profile_path : user_path(current_user)) %>

            <% unless current_page?(profile_link_path) %>
              <li style="display:inline; margin-left:1rem;">
                <%= link_to "Profile", profile_link_path %>
              </li>
            <% end %>

            <li style="display:inline; margin-left:1rem;">
              <%= link_to "Edit profile", edit_user_registration_path %>
            </li>

            <li style="display:inline; margin-left:1rem;">
              <%= link_to "Sign out", destroy_user_session_path, method: :delete, data: { confirm: "Sign out?" } %>
            </li>
          <% else %>
            <li style="display:inline; margin-left:1rem;">
              <%= link_to "Log in", new_user_session_path %>
            </li>
            <li style="display:inline; margin-left:1rem;">
              <%= link_to "Sign up", new_user_registration_path %>
            </li>
          <% end %>
        </ul>
      </nav>
    </header>

    <main class="container" style="margin-top: 1rem;">
      <% if flash.any? %>
        <section>
          <% flash.each do |k, v| %>
            <div style="color: <%= (k.to_s == 'notice' ? 'green' : 'red') %>;"><%= v %></div>
          <% end %>
        </section>
      <% end %>

      <%= yield %>
    </main>

    <footer class="container" style="margin-top: 2rem;">
      <!-- footer content if you want -->
    </footer>
  </body>
</html>
