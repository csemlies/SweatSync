<%= link_to "← Back to session", plan_session_path(@plan_session) %>

<h1>Add your busy times</h1>

<p>
  Session: <strong><%= @plan_session.title %></strong><br>
  You: <strong><%= @user.name %></strong>
</p>

<div
  data-controller="busy-calendar"
  data-busy-calendar-busy-starts-value="<%= @busy_blocks.map { |b| b.start_dt.iso8601 }.to_json %>"
>

  <label>Busy block length</label>
  <select data-busy-calendar-target="duration">
    <option value="30">30 min</option>
    <option value="60" selected>60 min</option>
    <option value="90">90 min</option>
    <option value="120">2 hours</option>
  </select>

  <%= form_with url: bulk_create_plan_session_busy_blocks_path(@plan_session),
                method: :post do %>

    <%= hidden_field_tag :user_id, @user.id %>
    <%= hidden_field_tag :duration_min, "60", data: { busy_calendar_target: "durationHidden" } %>
    <%= hidden_field_tag :starts, "", data: { busy_calendar_target: "startsHidden" } %>

    <button type="submit">Save busy times</button>
  <% end %>

  <table>
    <% @slots.each do |slot| %>
      <td
        class="slot"
        data-action="click->busy-calendar#toggle"
        data-busy-calendar-target="slot"
        data-start="<%= slot.iso8601 %>"
      >
        +
      </td>
    <% end %>
  </table>

</div>
