<p>
  <%= link_to "← Back to session", plan_session_path(@plan_session) %>
</p>

<h1>Add your busy times</h1>

<p>
  Session: <strong><%= @plan_session.title %></strong><br>
  You: <strong><%= @user.name.presence || @user.phone_number %></strong>
</p>

<div data-controller="busy-calendar"
     data-busy-calendar-plan-session-id-value="<%= @plan_session.id %>"
     data-busy-calendar-user-id-value="<%= @user.id %>"
     data-busy-calendar-create-url-value="<%= busy_blocks_path %>"
     data-busy-calendar-session-start-value="<%= @plan_session.start_date.to_date %>"
     data-busy-calendar-session-end-value="<%= @plan_session.end_date.to_date %>">

  <label><strong>Busy block length</strong></label><br>
  <select data-busy-calendar-target="duration">
    <option value="30">30 min</option>
    <option value="60" selected>60 min</option>
    <option value="90">90 min</option>
  </select>

  <!-- Hidden form that JS will submit -->
  <%= form_with url: busy_blocks_path, method: :post, data: { busy_calendar_target: "form" } do %>
    <%= hidden_field_tag :plan_session_id, @plan_session.id, data: { busy_calendar_target: "planSessionId" } %>
    <%= hidden_field_tag :user_id, @user.id, data: { busy_calendar_target: "userId" } %>
    <%= hidden_field_tag "busy_block[start_dt]", "", data: { busy_calendar_target: "startDt" } %>
    <%= hidden_field_tag "busy_block[end_dt]", "", data: { busy_calendar_target: "endDt" } %>
  <% end %>

  <hr style="margin:16px 0;">

  <table border="1" cellspacing="0" cellpadding="6" style="border-collapse:collapse; width:100%;">
    <thead>
      <tr>
        <th style="width:90px;">Time</th>
        <% @week_days.each do |d| %>
          <th>
            <div><strong><%= d.strftime("%a") %></strong></div>
            <div style="font-size:12px; color:#666;"><%= d.strftime("%m/%d") %></div>
          </th>
        <% end %>
      </tr>
    </thead>

    <tbody>
      <% start_time = 6 * 60   # 6:00am in minutes %>
      <% end_time   = 22 * 60  # 10:00pm in minutes %>
      <% step       = 30       # 30-min slots %>

      <% (start_time...end_time).step(step).each do |mins| %>
        <% hour = mins / 60 %>
        <% min  = mins % 60 %>
        <% label = Time.zone.parse("2000-01-01 #{format('%02d', hour)}:#{format('%02d', min)}").strftime("%-I:%M %p") %>

        <tr>
          <td style="white-space:nowrap;"><%= label %></td>

          <% @week_days.each do |day| %>
            <% in_range = (day >= @plan_session.start_date.to_date && day <= @plan_session.end_date.to_date) %>
            <% iso_start = Time.zone.local(day.year, day.month, day.day, hour, min).iso8601 %>

            <td style="<%= in_range ? '' : 'background:#f3f3f3; color:#999;' %>">
              <% if in_range %>
                <button type="button"
                        data-action="click->busy-calendar#slotClicked"
                        data-start="<%= iso_start %>"
                        style="width:100%; padding:8px; cursor:pointer;">
                  +
                </button>
              <% else %>
                —
              <% end %>
            </td>
          <% end %>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<hr style="margin:16px 0;">

<h3>Your saved busy blocks</h3>
<ul>
  <% @busy_blocks.each do |b| %>
    <li><%= b.start_dt.strftime("%a %m/%d %-I:%M %p") %> – <%= b.end_dt.strftime("%-I:%M %p") %></li>
  <% end %>
</ul>
