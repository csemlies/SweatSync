<%= link_to "← Back to session", plan_session_path(@plan_session) %>

<h1>Add your busy times</h1>

<p>
  Session: <strong><%= @plan_session.title %></strong><br>
  You: <strong><%= @user.name %></strong>
</p>

<p style="color:#555;">
  Click to select slots (light). Saved busy times show dark. Click a dark slot to remove it.
</p>

<%# Map existing busy blocks by start time (iso8601) so we can mark cells dark %>
<% busy_by_start = @busy_blocks.index_by { |b| b.start_dt.iso8601 } %>

<div
  data-controller="busy-calendar"
  data-busy-calendar-plan-session-id-value="<%= @plan_session.id %>"
>

  <label>Busy block length</label>
  <select data-busy-calendar-target="duration">
    <option value="30">30 min</option>
    <option value="60" selected>60 min</option>
    <option value="90">90 min</option>
    <option value="120">2 hours</option>
  </select>

  <%= form_with url: bulk_create_plan_session_busy_blocks_path(@plan_session),
                method: :post do %>

    <%= hidden_field_tag :user_id, @user.id %>
    <%= hidden_field_tag :duration_min, "60", data: { busy_calendar_target: "durationHidden" } %>
    <%= hidden_field_tag :starts, "", data: { busy_calendar_target: "startsHidden" } %>

    <button type="submit">Save busy times</button>
  <% end %>

  <table style="margin-top:16px; border-collapse: collapse;">
    <thead>
      <tr>
        <th style="border:1px solid #ccc; padding:8px; min-width:90px;">Time</th>
        <% @days.each do |day| %>
          <th style="border:1px solid #ccc; padding:8px; min-width:120px; text-align:center;">
            <div><%= day.strftime("%a") %></div>
            <div style="font-size:12px; color:#666;"><%= day.strftime("%m/%d") %></div>
          </th>
        <% end %>
      </tr>
    </thead>

    <tbody>
      <% @times.each do |t| %>
        <tr>
          <td style="border:1px solid #ccc; padding:8px; white-space:nowrap;">
            <%= t.strftime("%-I:%M %p") %>
          </td>

          <<% @days.each do |day| %>
  <% slot = Time.zone.local(day.year, day.month, day.day, t.hour, t.min) %>
  <% busy = busy_by_start[slot.iso8601] %>

  <% editable = (day >= @plan_session.start_date && day <= @plan_session.end_date) %>

  <td
    class="slot <%= "is-busy" if busy %> <%= "is-disabled" unless editable %>"
    style="border:1px solid #ccc; padding:6px; text-align:center;"
    <%= editable ? 'data-action="click->busy-calendar#toggle"' : "" %>
    data-busy-calendar-target="slot"
    data-start="<%= slot.iso8601 %>"
    data-busy-id="<%= busy&.id %>"
  >
            <%= busy ? "✓" : (editable ? "+" : "—") %>
          </td>
        <% end %>
      </tr>
    <% end %>
  </tbody>
</table>

</div>
