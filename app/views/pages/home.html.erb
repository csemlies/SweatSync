<div class="container">
  <!-- Hero -->
  <header>
    <h1>SweatSync</h1>
    <p class="lead">Plan workouts with friends without the group chat chaos.</p>
  </header>

  <!-- How it works -->
  <section>
    <h2>How it works</h2>

    <div class="grid">
      <article class="card">
        <h3>1. Create</h3>
        <p>Pick a day or week to work out.</p>
      </article>

      <article class="card">
        <h3>2. Share</h3>
        <p>Send your friends the QR link.</p>
      </article>

      <article class="card">
        <h3>3. Sweat</h3>
        <p>We find the best class for everyone.</p>
      </article>
    </div>
  </section>

  <!-- CTA: placed *after* How it works -->
  <section style="margin-top: 2rem;">
    <% if user_signed_in? %>
      <%= link_to "Create a session", new_plan_session_path, role: "button", class: "contrast" %>    <% else %>
      <!-- If user is not signed in, send to login, then they'll be able to create -->
      <%= link_to "Create a session", new_user_registration_path, role: "button", class: "contrast" %>
    <% end %>
  </section>
</div>
