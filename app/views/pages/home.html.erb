<div class="container">
  <header>
    <h1>SweatSync</h1>
    <p class="lead">Plan workouts with friends without the group chat chaos.</p>
  </header>

  <section>
    <h2>How it works</h2>

    <div class="grid">
      <article class="card">
        <h3>1. Create</h3>
        <p>Pick a day or week to work out.</p>
      </article>

      <article class="card">
        <h3>2. Share</h3>
        <p>Send your friends the QR link.</p>
      </article>

      <article class="card">
        <h3>3. Sweat</h3>
        <p>We find the best class for everyone.</p>
      </article>
    </div>
  </section>

  <section style="margin-top: 2rem; display: flex; gap: 1rem;">
  <% if user_signed_in? %>
    <%= link_to "Create a session", new_plan_session_path, class: "contrast", role: "button" %>
    <%= link_to "Join a session", join_path, role: "button" %>
  <% else %>
    <%= link_to "Create a session", auth_gate_path(redirect_to: new_plan_session_path), class: "contrast", role: "button" %>
    <%= link_to "Join a session", auth_gate_path(redirect_to: join_path), role: "button" %>
  <% end %>
</section>
</div>
