<div class="container">
  <h1>Create an account or log in</h1>

  <div class="grid" style="grid-template-columns: 1fr 340px; gap: 2rem; align-items:start;">
    <section class="card" style="padding:1.5rem;">
      <h2>Sign up</h2>

      <% signup_user = User.new %>
      <% devise_mapping = Devise.mappings[:user] %>

      <%= render "devise/shared/error_messages", resource: signup_user %>

      <%= form_for(signup_user, as: :user, url: registration_path(:user)) do |f| %>
        <%= hidden_field_tag :redirect_to, params[:redirect_to] if params[:redirect_to].present? %>

        <div class="field">
          <%= f.label :email %><br />
          <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "input" %>
        </div>

        <div class="field">
          <%= f.label :password %>
          <em>(6 characters minimum)</em><br />
          <%= f.password_field :password, autocomplete: "new-password", class: "input" %>
        </div>

        <div class="field">
          <%= f.label :password_confirmation %><br />
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "input" %>
        </div>

        <div class="field">
          <%= f.label :username %><br />
          <%= f.text_field :username, class: "input" %>
        </div>

        <div class="actions" style="margin-top:1rem;">
          <%= f.submit "Sign up", class: "contrast" %>
        </div>
      <% end %>
    </section>

    <aside class="card" style="padding:1.5rem; width:100%; max-width:320px;">
      <h3>Already have an account?</h3>

      <%= form_with scope: :user, url: session_path(:user), local: true do |f| %>
        <%= hidden_field_tag :redirect_to, params[:redirect_to] if params[:redirect_to].present? %>

        <div class="field">
          <%= f.label :email %><br />
          <%= f.email_field :email, autocomplete: "email", class: "input" %>
        </div>

        <div class="field">
          <%= f.label :password %><br />
          <%= f.password_field :password, autocomplete: "current-password", class: "input" %>
        </div>

        <div class="field">
          <%= f.check_box :remember_me %>
          <%= f.label :remember_me %>
        </div>

        <div class="actions" style="margin-top:1rem;">
          <%= f.submit "Log in", class: "contrast" %>
        </div>
      <% end %>

      <p style="margin-top:1rem;"><%= link_to "Forgot your password?", new_user_password_path %></p>
    </aside>
  </div>
</div>
