<div class="container">
  <h1><%= @user.username.presence || @user.email %>'s profile</h1>

  <dl>
    <dt>Email</dt>
    <dd><%= @user.email %></dd>

    <dt>Username</dt>
    <dd><%= @user.username.presence || "—" %></dd>
  </dl>

  <% if @user == current_user %>
    <%= link_to "Edit profile", edit_user_registration_path, class: "button" %>
  <% end %>
</div>
